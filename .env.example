# Execucao
MONITOR_INTERVAL_SECONDS=120
LOCK_FILE_PATH=data/megahub-monitor.lock

# Navegador / Playwright
BROWSER_HEADLESS=true
PLAYWRIGHT_CHANNEL=msedge
PLAYWRIGHT_TIMEOUT_MS=30000

# Persistencia / logs
DATABASE_PATH=data/megahub-monitor.db
LOG_FILE_PATH=data/logs/monitor.log

# Configuracao declarativa
CONTEXTS_CONFIG_PATH=config/contexts.toml
ROUTING_CONFIG_PATH=config/routing.toml

# Teams / Power Automate
TEAMS_WEBHOOK_URL=
TEAMS_REQUEST_TIMEOUT_SECONDS=15
