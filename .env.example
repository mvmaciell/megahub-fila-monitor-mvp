# URL alvo da tela monitorada
TARGET_URL=https://megahub.megawork.com/Chamado/MinhaFila
SOURCE_VIEW_NAME=Minha Fila
CONSULTANT_NAME=Marcus Vinicius Maciel Vieira

# Comportamento do monitor
MONITOR_INTERVAL_SECONDS=120
ONLY_OPEN=true
ONLY_ASSIGNED_TO_ME=true
FIRST_PAGE_ONLY=true

# Navegador / Playwright
BROWSER_HEADLESS=true
PLAYWRIGHT_CHANNEL=msedge
PLAYWRIGHT_TIMEOUT_MS=30000
BROWSER_PROFILE_DIR=data/browser-profile

# Persistencia / logs
DATABASE_PATH=data/megahub-monitor.db
LOG_FILE_PATH=data/logs/monitor.log

# Teams / Power Automate
TEAMS_WEBHOOK_URL=
TEAMS_REQUEST_TIMEOUT_SECONDS=15

